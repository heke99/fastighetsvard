# ================================================================
# SUPABASE + PRISMA
# ================================================================
# DATABASE_URL: Supabase Transaction Pooler (port 6543) för Vercel/runtime.
# Hämta i Supabase: Project Settings -> Database -> Connection string -> Transaction pooler.
# Lägg till pgbouncer=true och connection_limit=1 för Prisma i serverless.
DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1&sslmode=require"

# DIRECT_URL: direktanslutning eller Session Pooler för Prisma Migrate.
# IPv4-miljöer bör använda Session Pooler på port 5432.
DIRECT_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-eu-central-1.pooler.supabase.com:5432/postgres?sslmode=require"

# Supabase API-inställningar. Project URL och anon key är publika klientvärden.
NEXT_PUBLIC_SUPABASE_URL="https://PROJECT_REF.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"

# Endast server-side. Får aldrig exponeras med NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY="YOUR_SUPABASE_SERVICE_ROLE_KEY"

# ================================================================
# APP
# ================================================================
APP_URL="http://localhost:3000"

# Exakt 64 hex-tecken (32 byte), används för AES-256-kryptering.
# Generera: openssl rand -hex 32
APP_ENCRYPTION_KEY="0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef"

# Vercel skickar automatiskt detta som Authorization: Bearer <CRON_SECRET>.
# Generera: openssl rand -base64 32
CRON_SECRET="change-me-to-a-long-random-value"

# ================================================================
# E-POST VIA RESEND
# ================================================================
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxx"
EMAIL_FROM="Östgöta El Teknik <noreply@your-verified-domain.se>"
SUPPORT_EMAIL="info@ostgotaelteknik.se"

# Sätt true endast lokalt om du vill logga e-postlänkar i terminalen.
EMAIL_LOG_LINKS="false"

DATABASE_URL="SUPABASE_TRANSACTION_POOLER_URL"
DIRECT_URL="SUPABASE_SESSION_POOLER_URL"

NEXT_PUBLIC_SUPABASE_URL="https://DITT_PROJECT_REF.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="DIN_ANON_KEY"
SUPABASE_SERVICE_ROLE_KEY="DIN_SERVICE_ROLE_KEY"

APP_URL="http://localhost:3000"

APP_ENCRYPTION_KEY="DIN_64_TECKEN_HEXNYCKEL"
CRON_SECRET="DIN_CRON_SECRET"

RESEND_API_KEY=""
EMAIL_FROM="Östgöta El Teknik <noreply@din-doman.se>"
SUPPORT_EMAIL="info@ostgotaelteknik.se"
EMAIL_LOG_LINKS="true"