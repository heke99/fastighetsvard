# Supabase Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL="https://PROJECT_REF.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="sb_publishable_xxxxxxxxx"

# Server-only. Use the new Supabase secret key when available.
# Legacy service_role works as fallback but must never use NEXT_PUBLIC_ prefix.
SUPABASE_SECRET_KEY="sb_secret_xxxxxxxxx"

# Application
APP_URL="http://localhost:3000"
APP_ENCRYPTION_KEY="0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef"
CRON_SECRET="replace-with-at-least-16-random-characters"

# E-mail through Resend
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxx"
EMAIL_FROM="Östgöta El Teknik <noreply@your-verified-domain.se>"
SUPPORT_EMAIL="info@ostgotaelteknik.se"
EMAIL_LOG_LINKS="true"

# One-time local bootstrap; do not keep the password in Vercel.
BOOTSTRAP_ADMIN_EMAIL="admin@ostgotaelteknik.se"
BOOTSTRAP_ADMIN_PASSWORD="replace-with-a-strong-password"
