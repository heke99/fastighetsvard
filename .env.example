# PostgreSQL-anslutning
DATABASE_URL="postgresql://app:app@localhost:5432/fastighet?schema=public"

# Hemlighet för sessionssignering (minst 32 tecken, slumpad i produktion)
SESSION_SECRET="change-me-to-a-long-random-string"

# 64 hex-tecken (32 byte) AES-256-nyckel för kryptering av integrations-credentials
APP_ENCRYPTION_KEY="0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef"

# Publik bas-URL för appen (används i länkar i e-post/inbjudningar)
APP_URL="http://localhost:3000"

# Valfritt: SMTP för e-postutskick (loggas till konsol om ej satt)
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM="Östgöta El Teknik <noreply@ostgotaelteknik.se>"
