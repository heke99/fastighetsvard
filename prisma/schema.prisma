// Fastighetsplattform för Östgöta El Teknik
//
// Grundprinciper:
// - En person är EN rad i Person oavsett hur många roller den har
//   (sökande, hyresgäst, medsökande, borgensman, köpare, kontaktperson).
// - Ett objekt (Unit) är det fysiska objektet. Annonser (Listing) är separata
//   och ett objekt kan ha många annonser över tid.
// - Externa system (bokföring m.m.) mappas via ExternalReference – aldrig kopior.
// - Allt är tenant-isolerat via organizationId.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Organisation / tenant
// ---------------------------------------------------------------------------

model Organization {
  id        String   @id @default(cuid())
  name      String
  orgNumber String?  @unique
  email     String?
  phone     String?
  address   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users                  User[]
  persons                Person[]
  properties             Property[]
  units                  Unit[]
  listings               Listing[]
  applications           Application[]
  contracts              Contract[]
  invoices               Invoice[]
  payments               Payment[]
  maintenanceRequests    MaintenanceRequest[]
  workOrders             WorkOrder[]
  suppliers              Supplier[]
  documents              Document[]
  messages               Message[]
  notifications          Notification[]
  apiKeys                ApiKey[]
  webhookSubscriptions   WebhookSubscription[]
  webhookDeliveries      WebhookDelivery[]
  inboundWebhookEvents   InboundWebhookEvent[]
  integrationConnections IntegrationConnection[]
  integrationSyncJobs    IntegrationSyncJob[]
  syncReviewItems        SyncReviewItem[]
  auditEvents            AuditEvent[]
  roles                  Role[]
  savedSearches          SavedSearch[]
  favorites              Favorite[]
  offers                 Offer[]
  viewings               Viewing[]
  importJobs             ImportJob[]
  invitations            Invitation[]
  externalReferences     ExternalReference[]
  masterDataConfigs      MasterDataConfig[]
  buildings              Building[]
  terminations           Termination[]
  inspections            Inspection[]
}

// Konfiguration av vilket system som är master per dataområde
// (t.ex. fakturor ägs av bokföringssystemet).
model MasterDataConfig {
  id             String           @id @default(cuid())
  organizationId String
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  domain         MasterDataDomain
  masterSystem   String // "internal" eller providernamn, t.ex. "fortnox"
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@unique([organizationId, domain])
}

enum MasterDataDomain {
  CUSTOMERS
  INVOICES
  PAYMENTS
  CREDIT_NOTES
  REMINDERS
  LEDGER
  CONTRACTS
}

// ---------------------------------------------------------------------------
// Personer, användare, roller
// ---------------------------------------------------------------------------

// En person = en verklig människa/juridisk person. Alla roller pekar hit.
model Person {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  firstName         String
  lastName          String
  email             String?
  phone             String?
  personalNumber    String? // personnummer (känsligt – hanteras enligt GDPR)
  orgNumber         String? // för juridiska personer
  isCompany         Boolean   @default(false)
  companyName       String?
  address           String?
  postalCode        String?
  city              String?
  country           String    @default("SE")
  protectedIdentity Boolean   @default(false) // skyddade personuppgifter
  gdprAnonymizedAt  DateTime?
  notes             String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user                  User?
  roles                 PersonRole[]
  applicationMembers    ApplicationMember[]
  contractParties       ContractParty[]
  invoices              Invoice[]
  maintenanceRequests   MaintenanceRequest[]
  documents             Document[]
  favorites             Favorite[]
  savedSearches         SavedSearch[]
  offers                Offer[]
  viewingAttendees      ViewingAttendee[]
  invitations           Invitation[]
  externalReferences    ExternalReference[]
  messagesReceived      Message[]            @relation("MessageRecipient")
  messagesSent          Message[]            @relation("MessageSender")
  notifications         Notification[]
  terminationsRequested Termination[]

  @@unique([organizationId, email])
  @@index([organizationId, personalNumber])
  @@index([organizationId, lastName, firstName])
}

enum PersonRoleType {
  APPLICANT // bostadssökande
  TENANT // hyresgäst
  CO_APPLICANT // medsökande
  GUARANTOR // borgensman
  BUYER // köpare
  CONTACT // kontaktperson
  HOUSEHOLD_MEMBER
}

// En person kan ha flera roller samtidigt.
model PersonRole {
  id        String         @id @default(cuid())
  personId  String
  person    Person         @relation(fields: [personId], references: [id], onDelete: Cascade)
  role      PersonRoleType
  createdAt DateTime       @default(now())

  @@unique([personId, role])
}

model User {
  id             String  @id @default(cuid())
  organizationId String?
  personId       String? @unique
  person         Person? @relation(fields: [personId], references: [id])

  email               String    @unique
  passwordHash        String
  emailVerifiedAt     DateTime?
  phoneVerifiedAt     DateTime?
  twoFactorEnabled    Boolean   @default(false)
  twoFactorSecret     String?
  failedLoginAttempts Int       @default(0)
  lockedUntil         DateTime?
  lastLoginAt         DateTime?
  isActive            Boolean   @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization       Organization?        @relation(fields: [organizationId], references: [id])
  sessions           Session[]
  userRoles          UserRole[]
  passwordResets     PasswordResetToken[]
  auditEvents        AuditEvent[]
  assignedWorkOrders WorkOrder[]          @relation("WorkOrderAssignee")
  supplier           Supplier?            @relation(fields: [supplierId], references: [id])
  supplierId         String?

  @@index([email])
}

model Session {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  ip        String?
  userAgent String?
  createdAt DateTime  @default(now())
  revokedAt DateTime?

  @@index([userId])
  @@index([expiresAt])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
}

// Inbjudan till Mina sidor för befintliga hyresgäster.
model Invitation {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  personId       String
  person         Person       @relation(fields: [personId], references: [id], onDelete: Cascade)
  email          String
  tokenHash      String       @unique
  expiresAt      DateTime
  acceptedAt     DateTime?
  createdAt      DateTime     @default(now())

  @@index([organizationId, personId])
}

// Systemroller (RBAC). Superadmin kan skapa egna roller med valfria permissions.
model Role {
  id             String           @id @default(cuid())
  organizationId String?
  organization   Organization?    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  slug           String
  description    String?
  isSystem       Boolean          @default(false)
  permissions    RolePermission[]
  userRoles      UserRole[]
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@unique([organizationId, slug])
}

model RolePermission {
  id         String @id @default(cuid())
  roleId     String
  role       Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission String // t.ex. "units:read", "invoices:write", "contracts:approve"

  @@unique([roleId, permission])
}

model UserRole {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  roleId     String
  role       Role      @relation(fields: [roleId], references: [id], onDelete: Cascade)
  // Valfri avgränsning till fastighet: null = hela organisationen
  propertyId String?
  property   Property? @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  createdAt  DateTime  @default(now())

  @@unique([userId, roleId, propertyId])
}

// ---------------------------------------------------------------------------
// Fastighetsregister: Fastighet -> Byggnad -> Trapphus -> Våningsplan -> Objekt
// ---------------------------------------------------------------------------

model Property {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  name           String
  designation    String? // fastighetsbeteckning
  address        String
  postalCode     String?
  city           String
  municipality   String?
  country        String         @default("SE")
  ownerName      String?
  managerName    String?
  yearBuilt      Int?
  yearRenovated  Int?
  energyClass    String?
  insuranceInfo  String?
  contactInfo    String?
  emergencyPhone String?
  status         PropertyStatus @default(ACTIVE)
  notes          String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  buildings           Building[]
  units               Unit[]
  userRoles           UserRole[]
  documents           Document[]
  maintenanceRequests MaintenanceRequest[]

  @@index([organizationId, city])
}

enum PropertyStatus {
  ACTIVE
  UNDER_RENOVATION
  SOLD
  ARCHIVED
}

model Building {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  propertyId     String
  property       Property     @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  name           String
  address        String?
  yearBuilt      Int?
  floorsCount    Int?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  entrances Entrance[]
  units     Unit[]
}

model Entrance {
  id         String   @id @default(cuid())
  buildingId String
  building   Building @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  name       String // t.ex. "Trapphus A"
  address    String?

  floors Floor[]
  units  Unit[]
}

model Floor {
  id         String   @id @default(cuid())
  entranceId String
  entrance   Entrance @relation(fields: [entranceId], references: [id], onDelete: Cascade)
  level      Int
  name       String?

  units Unit[]
}

enum UnitType {
  APARTMENT // hyreslägenhet
  APARTMENT_SALE // bostad till salu
  COMMERCIAL // lokal
  OFFICE
  RETAIL
  WAREHOUSE
  GARAGE
  PARKING
  STORAGE // förråd
  STUDENT
  SHORT_TERM
  LAND
  PROPERTY_SALE // hel fastighet till salu
}

enum UnitStatus {
  DRAFT
  NOT_PUBLISHED
  UPCOMING // kommande ledigt
  PUBLISHED
  APPLICATION_OPEN
  VIEWING
  OFFER_SENT
  RESERVED
  CONTRACT_SENT
  RENTED
  FOR_SALE
  BIDDING
  SOLD
  RENOVATING
  BLOCKED
  NOT_RENTABLE
  ARCHIVED
}

model Unit {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  propertyId     String
  property       Property     @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  buildingId     String?
  building       Building?    @relation(fields: [buildingId], references: [id])
  entranceId     String?
  entrance       Entrance?    @relation(fields: [entranceId], references: [id])
  floorId        String?
  floor          Floor?       @relation(fields: [floorId], references: [id])
  parentUnitId   String? // underobjekt, t.ex. förråd som hör till lägenhet
  parentUnit     Unit?        @relation("UnitChildren", fields: [parentUnitId], references: [id])
  childUnits     Unit[]       @relation("UnitChildren")

  unitNumber         String // objektsnummer
  apartmentNumber    String? // lägenhetsnummer (Lantmäteriet)
  type               UnitType
  status             UnitStatus @default(DRAFT)
  address            String
  postalCode         String?
  city               String
  area               String? // område/stadsdel
  floorLevel         Int?
  rooms              Decimal?   @db.Decimal(4, 1)
  livingArea         Decimal?   @db.Decimal(8, 2) // boyta m2
  secondaryArea      Decimal?   @db.Decimal(8, 2) // biarea m2
  rent               Decimal?   @db.Decimal(12, 2) // månadshyra
  price              Decimal?   @db.Decimal(14, 2) // försäljningspris
  operatingCost      Decimal?   @db.Decimal(12, 2)
  deposit            Decimal?   @db.Decimal(12, 2)
  availableFrom      DateTime?
  noticePeriodMonths Int        @default(3)

  hasElevator         Boolean @default(false)
  hasBalcony          Boolean @default(false)
  hasPatio            Boolean @default(false)
  hasStorage          Boolean @default(false)
  hasParking          Boolean @default(false)
  furnished           Boolean @default(false)
  accessible          Boolean @default(false)
  petsAllowed         Boolean @default(false)
  smokingAllowed      Boolean @default(false)
  internetIncluded    Boolean @default(false)
  tvIncluded          Boolean @default(false)
  heatingIncluded     Boolean @default(false)
  waterIncluded       Boolean @default(false)
  electricityIncluded Boolean @default(false)
  shortTermAllowed    Boolean @default(false)
  seniorHousing       Boolean @default(false)
  studentHousing      Boolean @default(false)

  description   String?
  internalNotes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  media               UnitMedia[]
  listings            Listing[]
  contracts           Contract[]
  invoices            Invoice[]
  maintenanceRequests MaintenanceRequest[]
  documents           Document[]
  externalReferences  ExternalReference[]
  inspections         Inspection[]

  @@unique([organizationId, unitNumber])
  @@index([organizationId, status])
  @@index([organizationId, type, status])
  @@index([organizationId, city])
}

model UnitMedia {
  id        String    @id @default(cuid())
  unitId    String
  unit      Unit      @relation(fields: [unitId], references: [id], onDelete: Cascade)
  kind      MediaKind
  url       String
  caption   String?
  sortOrder Int       @default(0)
  createdAt DateTime  @default(now())
}

enum MediaKind {
  IMAGE
  VIDEO
  FLOORPLAN
  DOCUMENT
}

// ---------------------------------------------------------------------------
// Annonser
// ---------------------------------------------------------------------------

enum ListingCategory {
  RENTAL
  SALE
  COMMERCIAL
  PARKING
}

enum ListingStatus {
  DRAFT
  SCHEDULED
  PUBLISHED
  PAUSED
  UNPUBLISHED
  COMPLETED
}

model Listing {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  unitId         String
  unit           Unit         @relation(fields: [unitId], references: [id], onDelete: Cascade)

  title               String
  slug                String
  description         String
  category            ListingCategory
  status              ListingStatus   @default(DRAFT)
  publishAt           DateTime?
  publishedAt         DateTime?
  applicationDeadline DateTime?
  moveInDate          DateTime?
  rent                Decimal?        @db.Decimal(12, 2)
  price               Decimal?        @db.Decimal(14, 2)
  contactName         String?
  contactEmail        String?
  contactPhone        String?
  requirementProfile  String? // kravprofil
  queueRules          String? // köregler
  seoTitle            String?
  seoDescription      String?
  featured            Boolean         @default(false)
  unpublishedAt       DateTime?
  completedAt         DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  publications ListingPublication[]
  applications Application[]
  favorites    Favorite[]
  viewings     Viewing[]
  offers       Offer[]

  @@unique([organizationId, slug])
  @@index([organizationId, status, category])
}

model ListingPublication {
  id            String    @id @default(cuid())
  listingId     String
  listing       Listing   @relation(fields: [listingId], references: [id], onDelete: Cascade)
  channel       String // "web", "external_portal", "social", "broker", "api"
  publishedAt   DateTime?
  unpublishedAt DateTime?
  externalUrl   String?
  createdAt     DateTime  @default(now())
}

model Favorite {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  personId       String
  person         Person       @relation(fields: [personId], references: [id], onDelete: Cascade)
  listingId      String
  listing        Listing      @relation(fields: [listingId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())

  @@unique([personId, listingId])
}

model SavedSearch {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  personId       String
  person         Person       @relation(fields: [personId], references: [id], onDelete: Cascade)
  name           String
  criteria       Json // sökfilter
  emailAlerts    Boolean      @default(true)
  smsAlerts      Boolean      @default(false)
  lastNotifiedAt DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([personId])
}

// ---------------------------------------------------------------------------
// Ansökningar
// ---------------------------------------------------------------------------

enum ApplicationStatus {
  DRAFT
  SUBMITTED
  RECEIVED
  UNDER_REVIEW
  NEEDS_SUPPLEMENT
  QUALIFIED
  NOT_QUALIFIED
  VIEWING_OFFERED
  VIEWING_BOOKED
  OFFER_SENT
  ACCEPTED
  DECLINED
  CONTRACT_SENT
  CONTRACT_SIGNED
  CLOSED
  WITHDRAWN
}

model Application {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  listingId      String
  listing        Listing      @relation(fields: [listingId], references: [id], onDelete: Cascade)

  status             ApplicationStatus @default(DRAFT)
  isInternalTransfer Boolean           @default(false) // intern omflyttning
  desiredMoveInDate  DateTime?
  currentHousing     String?
  currentLandlord    String?
  employment         String?
  employer           String?
  employmentType     String?
  monthlyIncome      Decimal?          @db.Decimal(12, 2)
  otherIncome        String?
  references         String?
  pets               String?
  vehicles           String?
  specialNeeds       String?
  message            String?
  consentGivenAt     DateTime?
  submittedAt        DateTime?
  closedAt           DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members          ApplicationMember[]
  statusHistory    ApplicationStatusEvent[]
  offers           Offer[]
  documents        Document[]
  viewingAttendees ViewingAttendee[]

  @@index([organizationId, status])
  @@index([listingId, status])
}

enum ApplicationMemberRole {
  MAIN_APPLICANT
  CO_APPLICANT
  HOUSEHOLD_MEMBER
  CHILD
  GUARANTOR
}

model ApplicationMember {
  id            String                @id @default(cuid())
  applicationId String
  application   Application           @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  personId      String
  person        Person                @relation(fields: [personId], references: [id], onDelete: Cascade)
  role          ApplicationMemberRole
  createdAt     DateTime              @default(now())

  @@unique([applicationId, personId, role])
}

model ApplicationStatusEvent {
  id              String             @id @default(cuid())
  applicationId   String
  application     Application        @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  fromStatus      ApplicationStatus?
  toStatus        ApplicationStatus
  comment         String?
  changedByUserId String?
  createdAt       DateTime           @default(now())

  @@index([applicationId])
}

// ---------------------------------------------------------------------------
// Visningar & erbjudanden
// ---------------------------------------------------------------------------

enum ViewingKind {
  INDIVIDUAL
  GROUP
  DIGITAL
  SELF_SERVICE
}

model Viewing {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  listingId      String
  listing        Listing      @relation(fields: [listingId], references: [id], onDelete: Cascade)
  kind           ViewingKind  @default(INDIVIDUAL)
  startsAt       DateTime
  endsAt         DateTime
  maxAttendees   Int?
  location       String?
  notes          String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  attendees ViewingAttendee[]

  @@index([listingId, startsAt])
}

enum ViewingAttendeeStatus {
  INVITED
  BOOKED
  WAITLISTED
  CHECKED_IN
  ATTENDED
  NO_SHOW
  CANCELLED
}

model ViewingAttendee {
  id            String                @id @default(cuid())
  viewingId     String
  viewing       Viewing               @relation(fields: [viewingId], references: [id], onDelete: Cascade)
  personId      String
  person        Person                @relation(fields: [personId], references: [id], onDelete: Cascade)
  applicationId String?
  application   Application?          @relation(fields: [applicationId], references: [id])
  status        ViewingAttendeeStatus @default(BOOKED)
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  @@unique([viewingId, personId])
}

enum OfferStatus {
  SENT
  ACCEPTED
  DECLINED
  EXPIRED
  WITHDRAWN
}

model Offer {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  listingId      String
  listing        Listing      @relation(fields: [listingId], references: [id], onDelete: Cascade)
  applicationId  String
  application    Application  @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  personId       String
  person         Person       @relation(fields: [personId], references: [id], onDelete: Cascade)

  status             OfferStatus @default(SENT)
  expiresAt          DateTime
  respondedAt        DateTime?
  decisionNote       String?
  isInternalTransfer Boolean     @default(false)
  contractId         String? // avtal som skapades vid accept

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([applicationId])
  @@index([personId, status])
}

// ---------------------------------------------------------------------------
// Avtal
// ---------------------------------------------------------------------------

enum ContractType {
  RESIDENTIAL
  COMMERCIAL
  PARKING
  GARAGE
  STORAGE
  SHORT_TERM
  SUBLEASE
  ADDENDUM
  GUARANTEE
}

enum ContractStatus {
  DRAFT
  INTERNAL_REVIEW
  APPROVED
  SENT_FOR_SIGNING
  PARTIALLY_SIGNED
  SIGNED
  ACTIVE
  TERMINATED // uppsagt (löper ut)
  ENDED // avslutat
  RESCINDED // hävt
  ARCHIVED
}

model Contract {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  unitId         String
  unit           Unit         @relation(fields: [unitId], references: [id], onDelete: Cascade)

  contractNumber           String
  type                     ContractType   @default(RESIDENTIAL)
  status                   ContractStatus @default(DRAFT)
  startDate                DateTime
  endDate                  DateTime?
  noticePeriodMonths       Int            @default(3)
  rent                     Decimal        @db.Decimal(12, 2)
  rentAddons               Json? // tillägg: [{name, amount}]
  deposit                  Decimal?       @db.Decimal(12, 2)
  invoiceReference         String?
  isImported               Boolean        @default(false) // registrerat i efterhand
  replacesContractId       String? // intern flytt: nytt avtal ersätter gammalt
  terminatedAt             DateTime?
  terminationEffectiveDate DateTime?
  activatedAt              DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  parties            ContractParty[]
  versions           ContractVersion[]
  documents          Document[]
  invoices           Invoice[]
  statusHistory      ContractStatusEvent[]
  externalReferences ExternalReference[]
  terminations       Termination[]

  @@unique([organizationId, contractNumber])
  @@index([organizationId, status])
  @@index([unitId, status])
}

enum ContractPartyRole {
  LANDLORD
  TENANT
  CO_TENANT
  GUARANTOR
}

model ContractParty {
  id              String            @id @default(cuid())
  contractId      String
  contract        Contract          @relation(fields: [contractId], references: [id], onDelete: Cascade)
  personId        String
  person          Person            @relation(fields: [personId], references: [id], onDelete: Cascade)
  role            ContractPartyRole
  signedAt        DateTime?
  signatureMethod String? // "email_code", "bankid", "manual"
  createdAt       DateTime          @default(now())

  @@unique([contractId, personId, role])
}

// Signerade avtal får inte ändras – ny version skapas i stället.
model ContractVersion {
  id              String   @id @default(cuid())
  contractId      String
  contract        Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  versionNumber   Int
  content         Json // avtalsdata vid versionen
  documentHash    String? // hash av signerat dokument
  createdByUserId String?
  createdAt       DateTime @default(now())

  @@unique([contractId, versionNumber])
}

model ContractStatusEvent {
  id              String          @id @default(cuid())
  contractId      String
  contract        Contract        @relation(fields: [contractId], references: [id], onDelete: Cascade)
  fromStatus      ContractStatus?
  toStatus        ContractStatus
  comment         String?
  changedByUserId String?
  createdAt       DateTime        @default(now())

  @@index([contractId])
}

// Uppsägning
enum TerminationStatus {
  REQUESTED
  CONFIRMED
  INSPECTION_BOOKED
  COMPLETED
  CANCELLED
}

model Termination {
  id                  String            @id @default(cuid())
  organizationId      String
  organization        Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  contractId          String
  contract            Contract          @relation(fields: [contractId], references: [id], onDelete: Cascade)
  requestedByPersonId String
  requestedBy         Person            @relation(fields: [requestedByPersonId], references: [id])
  requestedAt         DateTime          @default(now())
  desiredMoveOutDate  DateTime
  earliestEndDate     DateTime // beräknat enligt uppsägningstid
  effectiveEndDate    DateTime?
  status              TerminationStatus @default(REQUESTED)
  reason              String?
  isInternalTransfer  Boolean           @default(false)
  newContractId       String? // vid intern flytt
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  @@index([contractId])
}

enum InspectionType {
  PRE_MOVE_OUT // förbesiktning
  FINAL // slutbesiktning
  MOVE_IN // inflyttningsbesiktning
}

model Inspection {
  id             String         @id @default(cuid())
  organizationId String
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  unitId         String
  unit           Unit           @relation(fields: [unitId], references: [id], onDelete: Cascade)
  type           InspectionType
  scheduledAt    DateTime?
  completedAt    DateTime?
  inspectorName  String?
  result         String?
  notes          String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([unitId])
}

// ---------------------------------------------------------------------------
// Ekonomi: fakturor, betalningar, externa referenser
// ---------------------------------------------------------------------------

enum InvoiceStatus {
  DRAFT
  SENT
  PARTIALLY_PAID
  PAID
  OVERDUE
  REMINDED
  COLLECTION // inkasso
  CREDITED
  CANCELLED // makulerad
  DISPUTED
}

model Invoice {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  personId       String
  person         Person       @relation(fields: [personId], references: [id])
  contractId     String?
  contract       Contract?    @relation(fields: [contractId], references: [id])
  unitId         String?
  unit           Unit?        @relation(fields: [unitId], references: [id])

  invoiceNumber    String
  status           InvoiceStatus @default(DRAFT)
  invoiceDate      DateTime
  dueDate          DateTime
  periodStart      DateTime?
  periodEnd        DateTime?
  totalAmount      Decimal       @db.Decimal(12, 2)
  vatAmount        Decimal       @default(0) @db.Decimal(12, 2)
  paidAmount       Decimal       @default(0) @db.Decimal(12, 2)
  currency         String        @default("SEK")
  ocr              String?
  bankgiro         String?
  reference        String?
  pdfUrl           String?
  reminderCount    Int           @default(0)
  isCreditNote     Boolean       @default(false)
  creditsInvoiceId String? // kreditfaktura pekar på ursprungsfakturan
  creditsInvoice   Invoice?      @relation("CreditNotes", fields: [creditsInvoiceId], references: [id])
  creditNotes      Invoice[]     @relation("CreditNotes")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lines              InvoiceLine[]
  paymentAllocations PaymentAllocation[]
  externalReferences ExternalReference[]
  statusHistory      InvoiceStatusEvent[]

  @@unique([organizationId, invoiceNumber])
  @@index([organizationId, status])
  @@index([personId, status])
  @@index([contractId])
}

model InvoiceLine {
  id          String  @id @default(cuid())
  invoiceId   String
  invoice     Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  description String
  quantity    Decimal @default(1) @db.Decimal(10, 2)
  unitPrice   Decimal @db.Decimal(12, 2)
  vatRate     Decimal @default(25) @db.Decimal(5, 2)
  amount      Decimal @db.Decimal(12, 2)
  sortOrder   Int     @default(0)
}

model InvoiceStatusEvent {
  id              String         @id @default(cuid())
  invoiceId       String
  invoice         Invoice        @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  fromStatus      InvoiceStatus?
  toStatus        InvoiceStatus
  source          String // "sync", "webhook", "manual", "system"
  comment         String?
  changedByUserId String?
  createdAt       DateTime       @default(now())

  @@index([invoiceId])
}

model Payment {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  amount         Decimal      @db.Decimal(12, 2)
  currency       String       @default("SEK")
  paidAt         DateTime
  method         String? // "bankgiro", "autogiro", "swish", "card"
  reference      String?

  createdAt DateTime @default(now())

  allocations        PaymentAllocation[]
  externalReferences ExternalReference[]

  @@index([organizationId, paidAt])
}

model PaymentAllocation {
  id        String   @id @default(cuid())
  paymentId String
  payment   Payment  @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  invoiceId String
  invoice   Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  amount    Decimal  @db.Decimal(12, 2)
  createdAt DateTime @default(now())

  @@unique([paymentId, invoiceId])
}

// Mappning mot externa system. En intern entitet kan ha referenser till
// flera externa system, men (system, entityType, externalId) är unik
// vilket förhindrar dubbletter vid import/webhooks.
model ExternalReference {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  externalSystem String // "fortnox", "visma", ...
  entityType     String // "customer", "invoice", "payment", "contract", "credit_note"
  externalId     String
  personId       String?
  person         Person?      @relation(fields: [personId], references: [id], onDelete: Cascade)
  invoiceId      String?
  invoice        Invoice?     @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  paymentId      String?
  payment        Payment?     @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  contractId     String?
  contract       Contract?    @relation(fields: [contractId], references: [id], onDelete: Cascade)
  unitId         String?
  unit           Unit?        @relation(fields: [unitId], references: [id], onDelete: Cascade)

  syncStatus      String    @default("synced") // "synced", "pending", "error", "review"
  lastSyncedAt    DateTime?
  sourceVersion   String?
  sourceUpdatedAt DateTime?
  metadata        Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, externalSystem, entityType, externalId])
  @@index([personId])
  @@index([invoiceId])
}

// ---------------------------------------------------------------------------
// Integrationer & synk
// ---------------------------------------------------------------------------

model IntegrationConnection {
  id                   String       @id @default(cuid())
  organizationId       String
  organization         Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  provider             String // "fortnox", "visma", "bjornlunden", "business_central", "mock"
  name                 String
  isActive             Boolean      @default(true)
  // Krypterade credentials (AES-256-GCM via app-nyckel)
  credentialsEncrypted String?
  settings             Json?
  webhookSecret        String? // hemlighet för inkommande webhooks från providern
  lastSyncAt           DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  syncJobs IntegrationSyncJob[]

  @@unique([organizationId, provider, name])
}

enum SyncJobStatus {
  PENDING
  RUNNING
  COMPLETED
  COMPLETED_WITH_ERRORS
  FAILED
}

model IntegrationSyncJob {
  id             String                @id @default(cuid())
  organizationId String
  organization   Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  connectionId   String
  connection     IntegrationConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  jobType        String // "customers", "invoices", "payments", "full"
  status         SyncJobStatus         @default(PENDING)
  startedAt      DateTime?
  finishedAt     DateTime?
  itemsProcessed Int                   @default(0)
  itemsCreated   Int                   @default(0)
  itemsUpdated   Int                   @default(0)
  itemsSkipped   Int                   @default(0)
  itemsFailed    Int                   @default(0)
  log            Json?
  error          String?
  correlationId  String?

  createdAt DateTime @default(now())

  reviewItems SyncReviewItem[]

  @@index([organizationId, status])
}

// Granskningskö: poster som inte kunde matchas automatiskt.
enum ReviewItemStatus {
  PENDING
  RESOLVED
  REJECTED
}

model SyncReviewItem {
  id               String              @id @default(cuid())
  organizationId   String
  organization     Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  syncJobId        String?
  syncJob          IntegrationSyncJob? @relation(fields: [syncJobId], references: [id])
  entityType       String // "customer", "invoice", "payment"
  externalSystem   String
  externalId       String
  payload          Json
  reason           String // varför den hamnade i kön
  status           ReviewItemStatus    @default(PENDING)
  resolvedByUserId String?
  resolvedAt       DateTime?
  resolutionNote   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, externalSystem, entityType, externalId, status])
  @@index([organizationId, status])
}

// ---------------------------------------------------------------------------
// Felanmälan & arbetsorder
// ---------------------------------------------------------------------------

enum MaintenanceStatus {
  RECEIVED
  CONFIRMED
  ASSESSING
  NEEDS_INFO
  ASSIGNED
  BOOKED
  IN_PROGRESS
  WAITING_TENANT
  WAITING_CONTRACTOR
  WAITING_MATERIAL
  DONE
  QUALITY_CHECK
  CLOSED
  REJECTED
  REOPENED
}

enum MaintenancePriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

model MaintenanceRequest {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  requestNumber  Int // löpnummer per organisation
  propertyId     String?
  property       Property?    @relation(fields: [propertyId], references: [id])
  unitId         String?
  unit           Unit?        @relation(fields: [unitId], references: [id])
  personId       String?
  person         Person?      @relation(fields: [personId], references: [id])

  status           MaintenanceStatus   @default(RECEIVED)
  priority         MaintenancePriority @default(NORMAL)
  category         String
  subcategory      String?
  room             String?
  title            String
  description      String
  discoveredAt     DateTime?
  contactPhone     String?
  preferredTime    String?
  masterKeyAllowed Boolean             @default(false)
  petsInHome       Boolean             @default(false)
  isEmergency      Boolean             @default(false)
  rating           Int?
  closedAt         DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  comments      MaintenanceComment[]
  statusHistory MaintenanceStatusEvent[]
  workOrders    WorkOrder[]
  documents     Document[]

  @@unique([organizationId, requestNumber])
  @@index([organizationId, status])
  @@index([personId])
}

model MaintenanceComment {
  id           String             @id @default(cuid())
  requestId    String
  request      MaintenanceRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  authorUserId String?
  authorName   String
  body         String
  isInternal   Boolean            @default(false)
  createdAt    DateTime           @default(now())

  @@index([requestId])
}

model MaintenanceStatusEvent {
  id              String             @id @default(cuid())
  requestId       String
  request         MaintenanceRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  fromStatus      MaintenanceStatus?
  toStatus        MaintenanceStatus
  comment         String?
  changedByUserId String?
  createdAt       DateTime           @default(now())

  @@index([requestId])
}

enum WorkOrderStatus {
  CREATED
  OFFERED // erbjuden till entreprenör
  ACCEPTED
  REJECTED
  BOOKED
  IN_PROGRESS
  DONE
  APPROVED
  INVOICED
  CANCELLED
}

model WorkOrder {
  id             String              @id @default(cuid())
  organizationId String
  organization   Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  requestId      String?
  request        MaintenanceRequest? @relation(fields: [requestId], references: [id])
  supplierId     String?
  supplier       Supplier?           @relation(fields: [supplierId], references: [id])
  assigneeUserId String?
  assignee       User?               @relation("WorkOrderAssignee", fields: [assigneeUserId], references: [id])

  orderNumber      Int
  status           WorkOrderStatus     @default(CREATED)
  priority         MaintenancePriority @default(NORMAL)
  title            String
  description      String
  accessInfo       String? // tillträdesinformation (endast för tilldelad entreprenör)
  scheduledAt      DateTime?
  completedAt      DateTime?
  timeReported     Decimal?            @db.Decimal(8, 2) // timmar
  materialsUsed    String?
  cost             Decimal?            @db.Decimal(12, 2)
  invoiceReference String?
  checklist        Json?
  notes            String?
  approvedByUserId String?
  approvedAt       DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  documents Document[]

  @@unique([organizationId, orderNumber])
  @@index([organizationId, status])
  @@index([supplierId, status])
}

model Supplier {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  orgNumber      String?
  email          String?
  phone          String?
  specialty      String? // el, vvs, bygg...
  isActive       Boolean      @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workOrders WorkOrder[]
  users      User[]

  @@index([organizationId])
}

// ---------------------------------------------------------------------------
// Dokument, meddelanden, notiser
// ---------------------------------------------------------------------------

enum DocumentType {
  CONTRACT
  TERMINATION
  INSPECTION_PROTOCOL
  KEY_RECEIPT
  INFO_LETTER
  INVOICE
  CREDIT_NOTE
  PAYMENT_PLAN
  POWER_OF_ATTORNEY
  SUBLEASE
  TRANSFER
  GUARANTEE
  SALE_DOCUMENT
  ENERGY_DECLARATION
  FLOORPLAN
  OTHER
}

model Document {
  id                   String              @id @default(cuid())
  organizationId       String
  organization         Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  type                 DocumentType
  title                String
  fileName             String
  mimeType             String
  sizeBytes            Int
  storageKey           String // sökväg i fillagring
  sha256               String // dokumenthash
  version              Int                 @default(1)
  personId             String?
  person               Person?             @relation(fields: [personId], references: [id])
  unitId               String?
  unit                 Unit?               @relation(fields: [unitId], references: [id])
  propertyId           String?
  property             Property?           @relation(fields: [propertyId], references: [id])
  contractId           String?
  contract             Contract?           @relation(fields: [contractId], references: [id])
  applicationId        String?
  application          Application?        @relation(fields: [applicationId], references: [id])
  maintenanceRequestId String?
  maintenanceRequest   MaintenanceRequest? @relation(fields: [maintenanceRequestId], references: [id])
  workOrderId          String?
  workOrder            WorkOrder?          @relation(fields: [workOrderId], references: [id])
  signStatus           String? // "unsigned", "pending", "signed"
  uploadedByUserId     String?
  retentionUntil       DateTime? // gallringsregel
  archivedAt           DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId, type])
  @@index([personId])
  @@index([contractId])
}

model Message {
  id                String       @id @default(cuid())
  organizationId    String
  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  senderPersonId    String?
  sender            Person?      @relation("MessageSender", fields: [senderPersonId], references: [id])
  recipientPersonId String
  recipient         Person       @relation("MessageRecipient", fields: [recipientPersonId], references: [id], onDelete: Cascade)
  subject           String
  body              String
  readAt            DateTime?
  createdAt         DateTime     @default(now())

  @@index([recipientPersonId, readAt])
}

enum NotificationChannel {
  EMAIL
  SMS
  IN_APP
  PUSH
}

model Notification {
  id             String              @id @default(cuid())
  organizationId String
  organization   Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  personId       String
  person         Person              @relation(fields: [personId], references: [id], onDelete: Cascade)
  channel        NotificationChannel @default(IN_APP)
  eventType      String // "application_received", "invoice_available", ...
  title          String
  body           String
  sentAt         DateTime?
  readAt         DateTime?
  error          String?
  createdAt      DateTime            @default(now())

  @@index([personId, readAt])
}

// ---------------------------------------------------------------------------
// API-nycklar, webhooks
// ---------------------------------------------------------------------------

model ApiKey {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  keyPrefix      String // första tecknen, för identifiering
  keyHash        String       @unique // sha256 av hela nyckeln
  scopes         String[] // t.ex. ["customers:read", "invoices:write"]
  allowedIps     String[]     @default([])
  isActive       Boolean      @default(true)
  lastUsedAt     DateTime?
  expiresAt      DateTime?
  revokedAt      DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  idempotencyRecords IdempotencyRecord[]

  @@index([organizationId])
}

model IdempotencyRecord {
  id             String   @id @default(cuid())
  apiKeyId       String
  apiKey         ApiKey   @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)
  idempotencyKey String
  requestHash    String
  responseStatus Int
  responseBody   Json
  createdAt      DateTime @default(now())
  expiresAt      DateTime

  @@unique([apiKeyId, idempotencyKey])
  @@index([expiresAt])
}

model WebhookSubscription {
  id                  String       @id @default(cuid())
  organizationId      String
  organization        Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  url                 String
  secret              String // för HMAC-signering av utgående events
  events              String[] // ["contract.signed", "tenant.created", ...]
  isActive            Boolean      @default(true)
  disabledAt          DateTime?
  disabledReason      String?
  consecutiveFailures Int          @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  deliveries WebhookDelivery[]

  @@index([organizationId, isActive])
}

enum WebhookDeliveryStatus {
  PENDING
  DELIVERED
  FAILED
  DEAD_LETTER
}

model WebhookDelivery {
  id             String                @id @default(cuid())
  organizationId String
  organization   Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  subscriptionId String
  subscription   WebhookSubscription   @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  eventId        String // unikt händelse-ID
  eventType      String
  payload        Json
  status         WebhookDeliveryStatus @default(PENDING)
  attempts       Int                   @default(0)
  lastAttemptAt  DateTime?
  nextAttemptAt  DateTime?
  lastStatusCode Int?
  lastError      String?
  deliveredAt    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([subscriptionId, eventId])
  @@index([status, nextAttemptAt])
}

// Inkommande webhooks – idempotency via (provider, eventId).
model InboundWebhookEvent {
  id              String       @id @default(cuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  provider        String
  eventId         String
  eventType       String
  payload         Json
  signatureValid  Boolean
  processedAt     DateTime?
  processingError String?
  createdAt       DateTime     @default(now())

  @@unique([organizationId, provider, eventId])
  @@index([organizationId, processedAt])
}

// ---------------------------------------------------------------------------
// Import
// ---------------------------------------------------------------------------

enum ImportJobStatus {
  PREVIEW
  RUNNING
  COMPLETED
  COMPLETED_WITH_ERRORS
  FAILED
  ROLLED_BACK
}

model ImportJob {
  id              String          @id @default(cuid())
  organizationId  String
  organization    Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  importType      String // "tenants", "units", "contracts", "properties"
  fileName        String?
  status          ImportJobStatus @default(PREVIEW)
  totalRows       Int             @default(0)
  successRows     Int             @default(0)
  errorRows       Int             @default(0)
  skippedRows     Int             @default(0)
  rowResults      Json? // [{row, status, message, entityId}]
  createdByUserId String?
  startedAt       DateTime?
  finishedAt      DateTime?

  createdAt DateTime @default(now())

  @@index([organizationId, status])
}

// ---------------------------------------------------------------------------
// Revisionslogg
// ---------------------------------------------------------------------------

model AuditEvent {
  id             String        @id @default(cuid())
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String?
  user           User?         @relation(fields: [userId], references: [id])
  actorType      String        @default("user") // "user", "api_key", "system", "webhook"
  actorId        String?
  action         String // "create", "update", "delete", "login", "status_change", ...
  entityType     String
  entityId       String?
  before         Json?
  after          Json?
  ip             String?
  correlationId  String?
  createdAt      DateTime      @default(now())

  @@index([organizationId, entityType, entityId])
  @@index([organizationId, createdAt])
}

// Räknare för löpnummer (ärendenummer, arbetsordernummer, avtal m.m.)
model Counter {
  id             String @id @default(cuid())
  organizationId String
  key            String
  value          Int    @default(0)

  @@unique([organizationId, key])
}
